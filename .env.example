DATABASE_URL=""
PUBLIC_SENTRY_DSN=""
NODE_ENV="development"

# Build-time only: token for uploading Sentry source maps during `vite build`.
# Mark as a secret in Railway (build scope). Build still succeeds without it,
# but source-map upload is skipped.
SENTRY_AUTH_TOKEN=""

# Public origin of the deployed app, used by @sveltejs/adapter-node behind
# Railway's proxy so POST form actions aren't rejected as cross-site. Set to the
# Railway URL first, then the custom domain after DNS cutover.
# e.g. ORIGIN="https://your-app.up.railway.app"
ORIGIN=""

# Only needed if you want the /api/cron/* HTTP routes to be callable. Scheduled
# work runs via Railway cron services (npm run populateLearningResources /
# cleanupGuests) which call the DB directly and don't need this.
CRON_SECRET=""
