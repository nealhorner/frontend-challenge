DATABASE_URL=""
PUBLIC_SENTRY_DSN=""
NODE_ENV="development"

# --- BetterAuth ---
# Secret used to sign sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public base URL of the app (used for OAuth callbacks/redirects).
# e.g. BETTER_AUTH_URL="http://localhost:5173" in dev.
BETTER_AUTH_URL=""

# OAuth provider credentials (email/password works without these).
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Build-time only: token for uploading Sentry source maps during `vite build`.
# Mark as a secret in Railway (build scope). Build still succeeds without it,
# but source-map upload is skipped.
SENTRY_AUTH_TOKEN=""

# Public origin of the deployed app, used by @sveltejs/adapter-node behind
# Railway's proxy so POST form actions aren't rejected as cross-site. Set to the
# Railway URL first, then the custom domain after DNS cutover.
# e.g. ORIGIN="https://your-app.up.railway.app"
ORIGIN=""
