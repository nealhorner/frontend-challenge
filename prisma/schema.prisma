generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Central user entity. Auth fields (name/email/emailVerified/image) and the
// anonymous-guest flag (isAnonymous) live here so BetterAuth can manage them
// directly while the app's domain relations (quizzes, stats, detail) stay put.
model User {
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  name          String      @default("")
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  // Replaces the old role === 'GUEST' concept. Set by the BetterAuth anonymous plugin.
  isAnonymous   Boolean     @default(false)
  quizzes       Quiz[]
  sessions      Session[]
  accounts      Account[]
  UserStats     UserStats?
  UserDetail    UserDetail?
}

// BetterAuth session table (replaces the custom UserSession). Multiple sessions
// per user are allowed, so userId is intentionally not unique.
model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@index([userId])
}

// BetterAuth account table: one row per linked credential/social account.
// providerId='credential' rows hold the (Argon2) password hash.
model Account {
  id                    String    @id @default(uuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accountId             String
  providerId            String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  @@index([userId])
}

// BetterAuth verification table (email-verify / password-reset tokens).
model Verification {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
}

model UserDetail {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  company   String?
  website   String?
  location  String?
  github    String?
  linkedIn  String?
  twitter   String?
  bluesky   String?
  pronouns  String?
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserStats {
  id                     String            @id @default(uuid())
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String            @unique
  totalQuizzesTaken      Int               @default(0)
  totalQuestionsAnswered Int               @default(0)
  totalCorrectAnswers    Int               @default(0)
  rank                   Int               @default(0)
  eloRating              Int               @default(1000)
  // Consecutive days (within STREAK_WINDOW_DAYS gaps) on which the user has
  // completed a quiz. Recomputed from UserStatsTrends after each completed quiz.
  currentStreak          Int               @default(0)
  longestStreak          Int               @default(0)
  updatedAt              DateTime          @updatedAt
  UserStatsTrends        UserStatsTrends[]

  @@index([userId])
}

model UserStatsTrends {
  id                     String    @id @default(uuid())
  userStats              UserStats @relation(fields: [userStatsId], references: [id], onDelete: Cascade)
  userStatsId            String
  date                   DateTime
  totalQuizzesTaken      Int       @default(0)
  totalQuestionsAnswered Int       @default(0)
  totalCorrectAnswers    Int       @default(0)
  rank                   Int       @default(0)
  eloRating              Int       @default(1000)
  updatedAt              DateTime  @updatedAt

  @@unique([userStatsId, date], name: "user_stats_trend_user_id_date")
  @@index([userStatsId])
}

model Quiz {
  id                 String         @id @default(uuid())
  title              String
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  score              Int            @default(0)
  isCompleted        Boolean        @default(false)
  startedTimestamp   DateTime       @default(now())
  completedTimestamp DateTime?
  quizQuestions      QuizQuestion[]

  @@index([userId])
}

model Question {
  id                    String         @id @default(uuid())
  family                String
  title                 String
  prompt                String
  type                  String
  multipleChoiceOptions String
  answers               String
  tags                  String
  eloRating             Int            @default(1000)
  quizQuestions         QuizQuestion[]
}

model QuizQuestion {
  quizId            String
  questionId        String
  answer            String?
  isAnswered        Boolean   @default(false)
  isCorrect         Boolean?
  askedTimestamp    DateTime?
  answeredTimestamp DateTime?
  quiz              Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question          Question  @relation(fields: [questionId], references: [id])

  @@id([quizId, questionId])
}

model LearningResources {
  id                                 Int                                  @id @default(autoincrement())
  title                              String                               @unique
  type                               String
  url                                String                               @unique
  imageUrl                           String?
  description                        String?
  LearningEngagementEvents           LearningEngagementEvents[]
  LearningEngagementEventsAggregated LearningEngagementEventsAggregated[]
}

model LearningEngagementEvents {
  id                   Int               @id @default(autoincrement())
  learningResourceId   Int
  learningResourceType String
  date                 DateTime
  learningResource     LearningResources @relation(fields: [learningResourceId], references: [id])
}

model LearningEngagementEventsAggregated {
  id                   Int               @id @default(autoincrement())
  learningResourceType String
  learningResourceId   Int
  date                 DateTime
  count                Int               @default(0)
  learningResource     LearningResources @relation(fields: [learningResourceId], references: [id])
}
